<style>

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --crimson: #8B1A1A; --gold: #C9A84C; --gold-light: #E2C97E;
  --dark: #0D0A07; --dark-warm: #161008;
  --parchment: #F2E8D0; --parchment-dark: #D4C5A0;
  --text-light: #EDE0C4; --text-muted: #9A8870;
  --orange: #e8692a; --border: #1c1c1c; --border2: #161616;
  --muted: #2e2b29; --dim: #5a5754; --body: #6e6b68; --light: #e0dbd5;
}
html { background: var(--dark); }
body { background: var(--dark); color: var(--light);
  font-family: 'Vazirmatn', Tahoma, Arial, sans-serif;
  -webkit-font-smoothing: antialiased; direction: rtl; }
::-webkit-scrollbar { width: 5px; }
::-webkit-scrollbar-track { background: var(--dark-warm); }
::-webkit-scrollbar-thumb { background: var(--gold); }

.topnav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 200;
  padding: 15px 52px;
  display: flex; align-items: center; justify-content: space-between;
  background: rgba(13,10,7,0.97);
  border-bottom: 1px solid rgba(201,168,76,0.12);
  direction: ltr;
}
.topnav-logo {
  font-family: 'Cinzel', Georgia, serif;
  font-size: 11px; letter-spacing: 3px;
  color: var(--gold); text-decoration: none; text-transform: uppercase;
}
.topnav-links { display: flex; gap: 28px; list-style: none; align-items: center; }
.topnav-links a {
  font-family: 'Cinzel', Georgia, serif;
  font-size: 10px; letter-spacing: 2px;
  color: var(--parchment-dark); text-decoration: none; text-transform: uppercase;
  transition: color 0.3s;
}
.topnav-links a:hover, .topnav-links a.active { color: var(--gold); }
.topnav-btn {
  font-family: 'Cinzel', Georgia, serif;
  font-size: 10px; letter-spacing: 2px;
  padding: 7px 18px; border: 1px solid var(--gold);
  color: var(--gold); text-decoration: none;
  text-transform: uppercase; transition: all 0.3s;
}
.topnav-btn:hover { background: var(--gold); color: var(--dark); }
.orange-bar { position: fixed; right: 0; top: 0; width: 3px; height: 100vh;
  background: linear-gradient(to bottom, var(--orange), transparent); z-index: 300; opacity: 0.8; }


@import url('https://fonts.googleapis.com/css2?family=Vazirmatn:wght@300;400;500&display=swap');

.page { max-width: 900px; margin: 0 auto; padding: 108px 56px 80px; position: relative; }
.page-bar { position: absolute; right: -56px; top: 44px; width: 3px; height: 148px; background: var(--orange); }

.cv-header { display: flex; justify-content: space-between; align-items: flex-start;
  gap: 36px; padding-bottom: 44px; border-bottom: 1px solid var(--border); margin-bottom: 52px;
  flex-direction: row-reverse; }
.header-right { flex: 1; text-align: right; }
.cv-name { font-size: 48px; font-weight: 500; letter-spacing: -1px; line-height: 1;
  color: #f4f0eb; margin-bottom: 8px; font-family: 'Vazirmatn', Tahoma, sans-serif; }
.cv-title { font-family: monospace; font-size: 10px; letter-spacing: 0.1em;
  color: var(--orange); margin-bottom: 18px; direction: rtl; }
.cv-summary { font-size: 13.5px; color: var(--body); line-height: 1.9;
  max-width: 480px; margin-bottom: 20px; font-weight: 300; }
.contacts { display: flex; flex-direction: column; gap: 5px; align-items: flex-end; }
.contact-item { display: flex; align-items: center; gap: 9px; flex-direction: row-reverse;
  font-family: monospace; font-size: 10.5px; color: var(--dim); letter-spacing: 0.03em; }
.contact-dot { width: 4px; height: 4px; border-radius: 50%;
  background: var(--orange); flex-shrink: 0; display: inline-block; }
.photo-wrap { position: relative; flex-shrink: 0; }
.photo-frame { position: absolute; inset: -6px; border: 1px solid rgba(232,105,42,0.3); z-index: 2; pointer-events: none; }
.photo { width: 110px; height: 130px; object-fit: cover; object-position: center top;
  display: block; filter: grayscale(15%) contrast(1.05); }

.grid { display: grid; grid-template-columns: 1fr 148px; column-gap: 40px; }
.sec-label { font-family: 'Vazirmatn', Tahoma, sans-serif; font-size: 9px; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--muted); padding-top: 4px; line-height: 1.6;
  text-align: right; grid-column: 2; }
.sec-content { margin-bottom: 44px; grid-column: 1; }

/* Reverse grid order for RTL: content first, label second */
.grid-row { display: contents; }

.pills { display: flex; flex-wrap: wrap; gap: 7px; justify-content: flex-end; }
.pill { font-size: 11px; padding: 4px 11px;
  color: #6a6764; background: #141414; border: 1px solid #202020; line-height: 1.5; }
.pill.a { color: var(--orange); background: rgba(232,105,42,0.07); border: 1px solid rgba(232,105,42,0.28); }

.exp { padding-bottom: 24px; margin-bottom: 24px; border-bottom: 1px solid var(--border2); text-align: right; }
.exp:last-child { padding-bottom: 0; margin-bottom: 0; border-bottom: none; }
.exp-head { display: flex; justify-content: space-between; align-items: baseline;
  gap: 12px; margin-bottom: 3px; flex-direction: row-reverse; }
.exp-role { font-size: 13.5px; color: var(--light); font-weight: 500; }
.exp-period { font-family: monospace; font-size: 9.5px; color: var(--muted);
  white-space: nowrap; flex-shrink: 0; letter-spacing: 0.06em; direction: ltr; }
.exp-co { font-size: 11px; color: var(--orange); letter-spacing: 0.02em; margin-bottom: 9px; font-family: monospace; direction: ltr; text-align: right; }
.exp-pts { display: flex; flex-direction: column; gap: 5px; }
.exp-pt { font-size: 12.5px; color: var(--body); line-height: 1.8; padding-right: 16px;
  position: relative; font-weight: 300; }
.exp-pt::before { content: "\2014"; position: absolute; right: 0; color: var(--muted); font-size: 11px; }

.edu { margin-bottom: 16px; text-align: right; }
.edu-deg { font-size: 13px; color: var(--light); line-height: 1.4; font-weight: 500; }
.edu-sch { font-size: 11px; color: var(--dim); margin-top: 2px; font-family: monospace; direction: ltr; text-align: right; }
.edu-yr { font-family: monospace; font-size: 9.5px; color: var(--muted); letter-spacing: 0.08em; margin-top: 2px; direction: ltr; text-align: right; }

.certs { display: flex; flex-direction: column; gap: 9px; }
.cert { font-size: 12.5px; color: var(--body); padding-right: 16px; position: relative;
  line-height: 1.7; font-weight: 300; text-align: right; }
.cert::before { content: "\2014"; position: absolute; right: 0; color: var(--muted); font-size: 11px; }

.cv-footer { margin-top: 48px; padding-top: 20px; border-top: 1px solid var(--border);
  display: flex; justify-content: space-between; align-items: center;
  flex-wrap: wrap; gap: 12px; flex-direction: row-reverse; }
.cv-footer-name { font-family: monospace; font-size: 9px; letter-spacing: 0.15em;
  text-transform: uppercase; color: var(--muted); direction: ltr; }
.cv-footer-links { display: flex; gap: 22px; flex-wrap: wrap; flex-direction: row-reverse; }
.cv-footer-link { font-family: monospace; font-size: 9px; letter-spacing: 0.12em;
  color: var(--muted); text-transform: uppercase; text-decoration: none; direction: ltr; }

@media (max-width: 640px) {
  .topnav { padding: 13px 20px; }
  .topnav-links { display: none; }
  .page { padding: 90px 24px 60px; }
  .grid { grid-template-columns: 1fr; }
  .sec-label { grid-column: 1; margin-bottom: 8px; }
  .sec-content { grid-column: 1; }
  .cv-header { flex-direction: column; }
}

</style>
</head>
